# Walrus upload relay host. Defaults to Mysten's testnet relay when unset.
# Switch to mainnet by setting:
#   VITE_WALRUS_UPLOAD_RELAY=https://upload-relay.mainnet.walrus.space
# Or point at a self-hosted relay you operate.
#
# Only `VITE_*` prefixed vars are exposed to the client bundle by Vite.
VITE_WALRUS_UPLOAD_RELAY=https://upload-relay.testnet.walrus.space
